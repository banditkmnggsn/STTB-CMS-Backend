// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentType {
  article
  video
  podcast
  bulletin
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  username     String    @unique @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(200)
  avatar       String?   @db.VarChar(500)
  roleId       String    @map("role_id") @db.Uuid
  role         Role      @relation(fields: [roleId], references: [id])
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  articles     NewsArticle[]
  mediaFiles   MediaFile[]
  auditLogs    AuditLog[]
  homeContents HomeContent[]
  leadContents LeadContent[]
  programs     Program[]
  settings     SiteSetting[]
  pages        Page[]

  @@map("users")
  @@index([email])
  @@index([roleId])
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  permissions Json     @db.JsonB
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]

  @@map("roles")
}

model HomeContent {
  id        String   @id @default(uuid()) @db.Uuid
  section   String   @db.VarChar(50)
  data      Json     @db.JsonB
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.Uuid
  updater   User?    @relation(fields: [updatedBy], references: [id])

  @@map("home_content")
  @@index([section])
}

model Program {
  id                  String   @id @default(uuid()) @db.Uuid
  slug                String   @unique @db.VarChar(100)
  title               String   @db.VarChar(200)
  degree              String   @db.VarChar(20)
  shortDescription    String?  @map("short_description") @db.Text
  heroImage           String?  @map("hero_image") @db.VarChar(500)
  heroDescription     String?  @map("hero_description") @db.Text
  academicInfo        Json?    @map("academic_info") @db.JsonB
  curriculumCategories Json?   @map("curriculum_categories") @db.JsonB
  courses             Json?    @db.JsonB
  graduateProfile     Json?    @map("graduate_profile") @db.JsonB
  careerOpportunities Json?    @map("career_opportunities") @db.JsonB
  concentrations      Json?    @db.JsonB
  ctaTitle            String?  @map("cta_title") @db.VarChar(200)
  ctaDescription      String?  @map("cta_description") @db.Text
  isActive            Boolean  @default(true) @map("is_active")
  seoTitle            String?  @map("seo_title") @db.VarChar(200)
  seoDescription      String?  @map("seo_description") @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  updatedBy           String?  @map("updated_by") @db.Uuid
  updater             User?    @relation(fields: [updatedBy], references: [id])

  @@map("programs")
  @@index([slug])
  @@index([isActive])
}

model Page {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique @db.VarChar(150)
  title     String   @db.VarChar(300)
  data      Json     @db.JsonB
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.Uuid
  updater   User?    @relation(fields: [updatedBy], references: [id])

  @@map("pages")
  @@index([slug])
  @@index([isActive])
}

model LeadContent {
  id        String   @id @default(uuid()) @db.Uuid
  section   String   @db.VarChar(50)
  data      Json     @db.JsonB
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.Uuid
  updater   User?    @relation(fields: [updatedBy], references: [id])

  @@map("lead_content")
  @@index([section])
}

model NewsArticle {
  id            String    @id @default(uuid()) @db.Uuid
  slug          String    @unique @db.VarChar(150)
  title         String    @db.VarChar(300)
  excerpt       String?   @db.Text
  content       String    @db.Text
  featuredImage String?   @map("featured_image") @db.VarChar(500)
  categoryId    String?   @map("category_id") @db.Uuid
  category      Category? @relation(fields: [categoryId], references: [id])
  authorId      String    @map("author_id") @db.Uuid
  author        User      @relation(fields: [authorId], references: [id])
  status        String    @default("draft") @db.VarChar(20)
  type          ContentType @default(article)
  mediaUrl      String?   @map("media_url") @db.VarChar(500)
  duration      String?   @db.VarChar(20)
  isFeatured    Boolean   @default(false) @map("is_featured")
  publishDate   DateTime? @map("publish_date")
  views         Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tags          ArticleTag[]

  @@map("news_articles")
  @@index([slug])
  @@index([status])
  @@index([type])
  @@index([publishDate])
  @@index([categoryId])
}

model ArticleTag {
  articleId String @map("article_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

model Event {
  id               String   @id @default(uuid()) @db.Uuid
  title            String   @db.VarChar(300)
  description      String?  @db.Text
  eventDate        DateTime @map("event_date") @db.Date
  eventTime        String?  @map("event_time") @db.VarChar(50)
  location         String?  @db.VarChar(200)
  category         String?  @db.VarChar(50)
  eventType        String?  @map("event_type") @db.VarChar(100)
  isLeadEvent      Boolean  @default(false) @map("is_lead_event")
  image            String?  @db.VarChar(500)
  registrationLink String?  @map("registration_link") @db.VarChar(500)
  capacity         Int?
  registeredCount  Int      @default(0) @map("registered_count")
  isFeatured       Boolean  @default(false) @map("is_featured")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("events")
  @@index([eventDate])
  @@index([isActive])
  @@index([isLeadEvent])
  @@index([eventType])
}

model Lecturer {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(200)
  position       String?  @db.VarChar(200)
  specialization String?  @db.VarChar(300)
  education      String?  @db.Text
  email          String?  @db.VarChar(255)
  imageUrl       String?  @map("image_url") @db.VarChar(500)
  order          Int      @default(0)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("lecturers")
  @@index([isActive])
  @@index([order])
}

model Inquiry {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  email     String   @db.VarChar(255)
  subject   String?  @db.VarChar(255)
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("inquiries")
  @@index([isRead])
  @@index([createdAt])
}

model Category {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @db.VarChar(100)
  slug        String     @unique @db.VarChar(100)
  description String?    @db.Text
  parentId    String?    @map("parent_id") @db.Uuid
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  color       String?    @db.VarChar(7)
  orderIndex  Int        @default(0) @map("order_index")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  articles    NewsArticle[]

  @@map("categories")
  @@index([slug])
  @@index([parentId])
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  articles  ArticleTag[]

  @@map("tags")
  @@index([slug])
}

model MediaFile {
  id           String   @id @default(uuid()) @db.Uuid
  filename     String   @db.VarChar(255)
  originalName String   @map("original_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  size         Int
  width        Int?
  height       Int?
  url          String   @db.VarChar(500)
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(500)
  altText      String?  @map("alt_text") @db.VarChar(300)
  title        String?  @db.VarChar(200)
  caption      String?  @db.Text
  description  String?  @db.Text
  folder       String?  @db.VarChar(100)
  uploadedBy   String?  @map("uploaded_by") @db.Uuid
  uploader     User?    @relation(fields: [uploadedBy], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("media_files")
  @@index([uploadedBy])
  @@index([folder])
}

model SiteSetting {
  id        String   @id @default(uuid()) @db.Uuid
  category  String   @unique @db.VarChar(50)
  data      Json     @db.JsonB
  updatedAt DateTime @default(now()) @map("updated_at")
  updatedBy String?  @map("updated_by") @db.Uuid
  updater   User?    @relation(fields: [updatedBy], references: [id])

  @@map("site_settings")
  @@index([category])
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  user          User?    @relation(fields: [userId], references: [id])
  action        String   @db.VarChar(50)
  resourceType  String   @map("resource_type") @db.VarChar(50)
  resourceId    String?  @map("resource_id") @db.Uuid
  resourceTitle String?  @map("resource_title") @db.VarChar(300)
  changes       Json?    @db.JsonB
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}
